# IncaCook Admin — environment variables
#
# Copy this file to `.env.local` and adjust the values for your setup:
#   cp .env.example .env.local
#
# Only NEXT_PUBLIC_* vars are read by the app (they are exposed to the browser).

# Base URL of the IncaCook backend (NestJS). The app appends `/v1` itself,
# so set this to the host origin only — do NOT include a trailing slash or `/v1`.
#
# Local IncaCook-Server (default when running the backend on your machine):
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001
#
# Production (Railway) — use this to point the admin panel at the live backend:
# NEXT_PUBLIC_API_BASE_URL=https://incacook-api-production.up.railway.app
